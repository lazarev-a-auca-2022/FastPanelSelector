# Copy to .env and adjust for local/dev use. All values have sane defaults
# in code (see internal/config/config.go) — this file only matters if you
# want to override them.

HTTP_PORT=8080
DB_PATH=./data/plans.db
FEED_PATH=./data/feed.xlsx
POLL_INTERVAL=15m
MAX_FEED_BYTES=10485760
LOG_LEVEL=info

# Used by docker-compose.yml to mount the host directory where the
# externally-regenerated feed file lands, read-only, inside the container.
FEED_HOST_DIR=./data/feed
